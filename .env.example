# Kanthari Command — Telegram ↔ Discord Bridge Bot

# Bot display name (optional)
# BOT_NAME=Kanthari Command

# Telegram Bot (from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token

# Discord Bot (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token

# Discord server (guild) ID where channels will be created
DISCORD_GUILD_ID=123456789012345678

# Role ID for admins who can view Support/Admin private channels
DISCORD_ADMIN_ROLE_ID=123456789012345678

# Optional: category and channel name overrides
# SUPPORT_CATEGORY_NAME=Support
# ADMIN_CATEGORY_NAME=Admin
# RULES_CATEGORY_NAME=Rules
# RULES_CHANNEL_ENGLISH=english-rules
# RULES_CHANNEL_MALAYALAM=malayalam-rules
# RULES_CHANNEL_HINDI=hindi-rules
# RULES_CHANNEL_MANGLISH=manglish-rules

# Optional: for Render/Railway health checks
# PORT=8080
